<% layout('layout') -%>
<h2>New Category</h2>
<form method="post" action="/categories">
  <label>Name<br><input name="name"></label><br>
  <button type="submit">Create</button>
</form>
<%- include('../partials/header', { title: 'New Category' }) %>
<section>
  <h2>Create Category</h2>
  <form id="newCategoryForm" action="/new-category" method="post">
    <div>
      <label for="name">Name</label>
      <input id="name" name="name" type="text" maxlength="100" value="<%= old.name || '' %>" required>
    </div>
    <% if (errors && errors.length) { %>
      <ul>
        <% errors.forEach(function(e){ %>
          <li><%= e.msg %></li>
        <% }) %>
      </ul>
    <% } %>
    <button type="submit">Create</button>
  </form>
</section>
<script src="/js/validation.js"></script>
<%- include('../partials/footer') %>
