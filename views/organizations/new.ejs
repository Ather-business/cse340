<% layout('layout') -%>
<h2>New Organization</h2>
<form method="post" action="/organizations">
  <label>Name<br><input name="name"></label><br>
  <label>Description<br><textarea name="description"></textarea></label><br>
  <button type="submit">Create</button>
</form>
<%- include('../partials/header', { title: 'New Organization' }) %>
<section>
  <h2>Create Organization</h2>
  <form id="newOrganizationForm" action="/new-organization" method="post">
    <div>
      <label for="name">Name</label>
      <input id="name" name="name" type="text" maxlength="100" value="<%= old.name || '' %>" required>
    </div>
    <div>
      <label for="description">Description</label>
      <textarea id="description" name="description" maxlength="500" required><%= old.description || '' %></textarea>
    </div>
    <div>
      <label for="city">City</label>
      <input id="city" name="city" type="text" maxlength="100" value="<%= old.city || '' %>" required>
    </div>
    <div>
      <label for="state">State</label>
      <input id="state" name="state" type="text" maxlength="2" value="<%= old.state || '' %>" required placeholder="e.g., UT">
    </div>
    <% if (errors && errors.length) { %>
      <ul>
        <% errors.forEach(function(e){ %>
          <li><%= e.msg %></li>
        <% }) %>
      </ul>
    <% } %>
    <button type="submit">Create</button>
  </form>
</section>
<script src="/js/validation.js"></script>
<%- include('../partials/footer') %>
