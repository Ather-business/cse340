<% layout('layout') -%>
<h2>Edit Category</h2>
<form method="post" action="/categories/<%= category.id %>">
  <label>Name<br><input name="name" value="<%= category.name %>"></label><br>
  <button type="submit">Save</button>
</form>
<%- include('../partials/header', { title: 'Edit Category' }) %>
<section>
  <h2>Edit Category</h2>
  <form id="editCategoryForm" action="/edit-category/<%= old.id %>" method="post">
    <div>
      <label for="name">Name</label>
      <input id="name" name="name" type="text" maxlength="100" value="<%= old.name || '' %>" required>
    </div>
    <% if (errors && errors.length) { %>
      <ul>
        <% errors.forEach(function(e){ %>
          <li><%= e.msg %></li>
        <% }) %>
      </ul>
    <% } %>
    <button type="submit">Save</button>
  </form>
</section>
<script src="/js/validation.js"></script>
<%- include('../partials/footer') %>
