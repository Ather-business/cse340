<% layout('layout') -%>
<h2>Edit Project</h2>
<form method="post" action="/projects/<%= project.id %>">
  <label>Name<br><input name="name" value="<%= project.name %>"></label><br>
  <label>Description<br><textarea name="description"><%= project.description %></textarea></label><br>
  <label>Organization<br>
    <select name="organizationId">
      <option value="">-- none --</option>
      <% orgs.forEach(function(o){ %>
        <option value="<%= o.id %>" <%= project.organizationId===o.id? 'selected':'' %>><%= o.name %></option>
      <% }) %>
    </select>
  </label><br>
  <button type="submit">Save</button>
</form>
<%- include('../partials/header', { title: 'Edit Project' }) %>
<section>
  <h2>Edit Project</h2>
  <form id="editProjectForm" action="/edit-project/<%= old.id %>" method="post">
    <div>
      <label for="name">Name</label>
      <input id="name" name="name" type="text" maxlength="100" value="<%= old.name || '' %>" required>
    </div>
    <div>
      <label for="description">Description</label>
      <textarea id="description" name="description" maxlength="500"><%= old.description || '' %></textarea>
    </div>
    <div>
      <label for="date">Service Date</label>
      <input id="date" name="date" type="date" value="<%= old.date || '' %>" required>
    </div>
    <div>
      <label for="organization_id">Organization</label>
      <select id="organization_id" name="organization_id">
        <option value="">None</option>
        <% organizations.forEach(function(org){ %>
          <option value="<%= org.id %>" <%= old.organization_id == org.id ? 'selected' : '' %>><%= org.name %></option>
        <% }) %>
      </select>
    </div>
    <% if (errors && errors.length) { %>
      <ul>
        <% errors.forEach(function(e){ %>
          <li><%= e.msg %></li>
        <% }) %>
      </ul>
    <% } %>
    <button type="submit">Save</button>
  </form>
</section>
<script src="/js/validation.js"></script>
<%- include('../partials/footer') %>
